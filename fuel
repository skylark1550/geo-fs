// Global constants and helpers — defined OUTSIDE the IIFE so that
// window.fuelTick, window.fuelInit, window.computeBurnGalPerSec etc.
// (all defined at global scope later in the file) can always reach them.
window.GAL_TO_LITERS = 3.78541;
window.GAL_TO_KG = 3.043;        // Jet-A: 0.804 kg/L × 3.78541 L/gal
window.GAL_TO_KG_AVGAS = 2.725;  // AvGas 100LL: 0.72 kg/L × 3.78541 L/gal

window.fuel = {
    lastId: -1,
    gphIdle: -1,
    gphMax: -1,
    capacity: -1,
    left: -1,
    isRefueling: false,
    refuelTarget: -1,
    refuelRatePerSec: -1,
    nextTick: -1,
    firstAudio: new Audio("https://tylerbmusic.github.io/GPWS-files_geofs/fuelNotify.wav"),
};

window.getKgPerGal = function (stats) {
    if (!stats) return window.GAL_TO_KG;
    if (stats.isJet) return window.GAL_TO_KG;
    // turboprops burn Jet-A; pistons burn AvGas
    return stats.isTurboprop ? window.GAL_TO_KG : window.GAL_TO_KG_AVGAS;
};

(function () {
    'use strict';

    // Addon menu
    if (!window.gmenu || !window.GMenu) {
        fetch("https://raw.githubusercontent.com/tylerbmusic/GeoFS-Addon-Menu/refs/heads/main/addonMenu.js")
            .then(r => r.text())
            .then(script => { eval(script); })
            .then(() => { setTimeout(afterGMenu, 100); });
    } else afterGMenu();

    async function afterGMenu() {
        const m = new window.GMenu("Fuel", "fuel");
        m.addItem("Fuel low warning threshold %: ", "Threshold", "number", 0, "0.15", 'min=0 max=1 step=0.01');
        // Refuel amount in kg
        m.addItem("Refuel target (kg): ", "Amount", "number", 0, "0", "min=0");
        // Pump rate in kg/min — realistic: ~500–1500 kg/min for airliners, ~30–60 for GA
        m.addItem("Pump rate (kg/min): ", "PumpRate", "number", 0, "150", "min=1");
        m.addItem("Allow midair refueling: ", "AirRefuel", "checkbox", 0, "false");

        window.fuel.refuel = function () {
            const stats = window.fuel.currentStats;
            const kgPerGal = window.getKgPerGal(stats);

            // User inputs are in kg; convert to gallons for internal storage
            let targetKg = Number(localStorage.getItem("fuelAmount"));
            let targetGal = targetKg / kgPerGal;
            targetGal = Math.max(0, Math.min(targetGal, window.fuel.capacity));

            let pumpRateKgMin = Number(localStorage.getItem("fuelPumpRate")) || 150;
            let pumpRateGalMin = pumpRateKgMin / kgPerGal;
            let pumpRateGalSec = pumpRateGalMin / 60;

            window.fuel.refuelTarget = targetGal;
            window.fuel.refuelRatePerSec = (targetGal >= window.fuel.left) ? pumpRateGalSec : -pumpRateGalSec;
            window.fuel.isRefueling = true;
            console.log(`Refueling to ${targetKg.toFixed(0)} kg (${targetGal.toFixed(1)} gal) at ${pumpRateKgMin.toFixed(1)} kg/min`);
        };
        m.addButton("REFUEL", window.fuel.refuel, 'onclick="window.fuel.refuel()"');

        // LOW FUEL alarm element
        const a = document.getElementsByClassName("geofs-alarms-container")[0];
        a.innerHTML += `<div class="geofs-inline-overlay geofs-textOverlay control-pad-transparent orange-pad control-pad-dyn-label geofs-hidden" style="background-size:100px 25px;margin-left:0;margin-bottom:0;z-index:60;width:100px;height:25px;opacity:1;" id="lowfuel">LOW FUEL</div>`;

        fWait();
    }
})();

function fWait() {
    if (window.geofs.cautiousWithTerrain == false && window.geofs.aircraft.instance && window.geofs.animation) {
        setTimeout(window.fuelInit, 3000);
    } else {
        setTimeout(fWait, 1000);
    }
}

window.fuelInit = function () {
    window.fuel.nextTick = Date.now() + 1000;

    // HUD display
    let el = document.getElementById('fuelHUD');
    if (!el) {
        el = document.createElement('div');
        el.id = 'fuelHUD';
        Object.assign(el.style, {
            position: 'fixed',
            bottom: '0',
            right: 'calc(10px + 48px + 16px)',
            height: '44px',
            minWidth: '220px',
            padding: '0 16px',
            display: 'inline-flex',
            flexDirection: 'column',
            justifyContent: 'center',
            fontFamily: '"Roboto Mono", "Roboto", monospace',
            fontSize: '12px',
            color: '#000',
            zIndex: '9999',
            lineHeight: '1.4',
            textTransform: 'uppercase',
        });
        document.body.appendChild(el);
    }

    // Circular gauge in pad area
    const afuelGauge = document.createElement('div');
    afuelGauge.id = 'afuelGauge';
    afuelGauge.style.cssText = 'width:50px;height:50px;border-radius:50%;cursor:default!important;';
    afuelGauge.className = "geofs-inline-overlay geofs-textOverlay control-pad geofs-manipulator geofs-visible";
    document.getElementsByClassName("geofs-pads-container")[0].prepend(afuelGauge);
    afuelGauge.innerHTML = `
        <div id="fuelGauge" style="background-image:url(https://tylerbmusic.github.io/GPWS-files_geofs/fuel_meter.png);width:50px;height:50px;background-size:100%;position:absolute;top:0;"></div>
        <div id="fuelHandle" style="background-image:url(https://tylerbmusic.github.io/GPWS-files_geofs/fuel_handle.png);background-size:100%;width:50px;height:50px;position:absolute;top:0;transform-origin:24.5px 33.75px;"></div>
    `;

    if (!localStorage.getItem("fuelFirstTime")) {
        localStorage.setItem("fuelFirstTime", "false");
        window.fuel.firstAudio.play();
    }

    window.fuelTick();
};

// ─── Fuel burn model ────────────────────────────────────────────────────────
// Real jet engines burn fuel roughly proportional to thrust (not throttle).
// GeoFS exposes geofs.animation.values.thrust (in Newtons for jets) and
// smoothThrottle. We use a two-point linear interpolation between idle burn
// and max-rated burn, keyed to the *throttle position* as a proxy for
// normalised thrust. This is imperfect but far better than raw throttle.
//
// For props/pistons, burn scales with throttle more linearly (mixture-leaned
// cruise vs full rich climb), so we use a gentler curve.
//
// Afterburner: doubles fuel flow when AB is active and throttle > 90%.
// ────────────────────────────────────────────────────────────────────────────
function computeBurnGalPerSec() {
    const v = window.geofs.animation.values;
    const eng = window.geofs.aircraft.instance.engine;

    if (!eng || !eng.on) return 0;
    if (window.geofs.isPaused()) return 0;

    const throttle = Math.max(0, Math.min(v.smoothThrottle || 0, 1));
    const stats = window.fuel.currentStats; // { gphIdle, gphMax, isJet, hasAB }

    if (!stats || stats.gphIdle < 0) return 0;

    let gph;
    if (stats.isJet) {
        // Jets: idle burn even at zero throttle, non-linear toward max
        // Use square-root curve to approximate thrust vs throttle non-linearity
        const t = Math.sqrt(throttle);
        gph = stats.gphIdle + (stats.gphMax - stats.gphIdle) * t;

        // Afterburner roughly doubles flow when active
        if (stats.hasAB && throttle > 0.9) {
            const abFraction = (throttle - 0.9) / 0.1; // 0→1 as throttle goes 90→100%
            gph += gph * abFraction;
        }
    } else {
        // Piston/turboprop: more linear, idle burn near zero
        gph = stats.gphIdle + (stats.gphMax - stats.gphIdle) * throttle;
    }

    return gph / 3600; // convert to gal/sec
}

window.fuelTick = function () {
    if (localStorage.getItem("fuelEnabled") != "true") {
        setTimeout(window.fuelTick, 500);
        return;
    }

    const now = Date.now();
    if (now < window.fuel.nextTick) {
        setTimeout(window.fuelTick, 10);
        return;
    }
    window.fuel.nextTick += 1000;

    // ── Aircraft change ──────────────────────────────────────────────────────
    const currentId = Number(window.geofs.aircraft.instance.id);
    if (window.fuel.lastId !== currentId) {
        window.fuel.lastId = currentId;
        window.fuel.currentStats = window.fuel.getStats(currentId); // always in gallons
        window.fuel.capacity = window.fuel.currentStats.capacity;
        window.fuel.left = window.fuel.capacity * 0.5; // start at 50%
        window.fuel.isRefueling = false;
        console.log(`Fuel: loaded aircraft ${currentId}`, window.fuel.currentStats);
    }

    // kgPerGal MUST be computed after currentStats is (potentially) updated above
    const kgPerGal = window.getKgPerGal(window.fuel.currentStats);

    // Update refuel input max now that we have correct kgPerGal
    const amtEl = document.getElementById("fuelAmount");
    if (amtEl && window.fuel.capacity > 0) amtEl.max = Math.round(window.fuel.capacity * kgPerGal);

    const lowAlarm = document.getElementById("lowfuel");
    const hudEl = document.getElementById("fuelHUD");
    const handleEl = document.getElementById("fuelHandle");

    if (window.fuel.capacity <= 0) {
        if (hudEl) hudEl.innerHTML = `<span>No fuel data for this aircraft</span>`;
        setTimeout(window.fuelTick, 10);
        return;
    }

    // ── Burn fuel ────────────────────────────────────────────────────────────
    const burnGalSec = computeBurnGalPerSec();
    const burnGalHr  = burnGalSec * 3600;

    if (window.fuel.left > 0) {
        window.fuel.left = Math.max(0, window.fuel.left - burnGalSec);

        // Adjust aircraft weight for remaining fuel mass
        const GRAVITY = 9.81;
        const fuelMassKg = window.fuel.left * kgPerGal;
        try {
            window.geofs.aircraft.instance.rigidBody.gravityForce[2] =
                -(window.geofs.aircraft.instance.rigidBody.mass * GRAVITY + fuelMassKg * GRAVITY);
        } catch (e) { /* some aircraft don't expose rigidBody */ }
    } else {
        // Out of fuel — kill engine
        try { window.geofs.aircraft.instance.stopEngine(); } catch (e) {}
        try { window.controls.throttle = 0; } catch (e) {}
    }

    // ── Refueling ────────────────────────────────────────────────────────────
    if (window.fuel.isRefueling) {
        const onGround  = window.geofs.animation.values.groundContact
                       || (window.geofs.animation.values.groundSpeed || 0) < 1;
        const stationary = (window.geofs.animation.values.groundSpeed || 0) < 5;
        const airRefuel  = localStorage.getItem("fuelAirRefuel") == 'true';
        const canRefuel  = (onGround && stationary) || airRefuel;

        if (!canRefuel) {
            window.fuel.isRefueling = false;
            alert("To refuel: be on the ground and stationary.");
        } else {
            const rate   = window.fuel.refuelRatePerSec;
            const newLeft = window.fuel.left + rate;

            if (rate > 0 && newLeft >= window.fuel.refuelTarget) {
                window.fuel.left = window.fuel.refuelTarget;
                window.fuel.isRefueling = false;
                console.log("Refueling complete.");
            } else if (rate < 0 && newLeft <= window.fuel.refuelTarget) {
                window.fuel.left = window.fuel.refuelTarget;
                window.fuel.isRefueling = false;
                console.log("Defueling complete.");
            } else {
                window.fuel.left = Math.max(0, Math.min(newLeft, window.fuel.capacity));
            }
        }
    }

    // ── HUD update ───────────────────────────────────────────────────────────
    const pct = window.fuel.left / window.fuel.capacity;

    // All displayed in kg
    const leftKg  = Math.round(window.fuel.left     * kgPerGal);
    const capKg   = Math.round(window.fuel.capacity  * kgPerGal);
    const flowKgh = Math.round(burnGalHr             * kgPerGal);

    // Time remaining estimate (avoid division by zero)
    let timeStr = '∞';
    if (burnGalSec > 0.0001) {
        const secsLeft = window.fuel.left / burnGalSec;
        const hrs = Math.floor(secsLeft / 3600);
        const mins = Math.floor((secsLeft % 3600) / 60);
        timeStr = `${hrs}h ${mins}m`;
    }

    const refuelTargetKg = Math.round(window.fuel.refuelTarget * kgPerGal);
    const refuelStatus = window.fuel.isRefueling ? ` [REFUELING→${refuelTargetKg}KG]` : '';

    if (hudEl) {
        hudEl.innerHTML = `
            <span>FUEL: ${leftKg}/${capKg} KG (${Math.round(pct * 100)}%)${refuelStatus}</span>
            <span style="font-size:11px;opacity:0.75;">FLOW: ${flowKgh} KG/HR &nbsp;|&nbsp; ENDURANCE: ${timeStr}</span>
        `;
    }

    if (handleEl) {
        // Gauge needle: -42° = empty, +42° = full
        handleEl.style.transform = `rotate(${(84 * pct - 42).toFixed(1)}deg)`;
    }

    // ── Low fuel alarm ───────────────────────────────────────────────────────
    if (lowAlarm) {
        const isLow = pct <= Number(localStorage.getItem("fuelThreshold") || 0.15);
        const classes = lowAlarm.className.split(" ");
        const hiddenIdx = classes.indexOf("geofs-hidden");
        const visibleIdx = classes.indexOf("geofs-visible");

        if (isLow && hiddenIdx !== -1) {
            classes[hiddenIdx] = "geofs-visible";
            lowAlarm.className = classes.join(" ");
        } else if (!isLow && visibleIdx !== -1) {
            classes[visibleIdx] = "geofs-hidden";
            lowAlarm.className = classes.join(" ");
        }
    }

    setTimeout(window.fuelTick, 10);
};

// ─── Aircraft stats ─────────────────────────────────────────────────────────
// All values stored in US gallons internally.
// gphIdle:     fuel flow at idle thrust (engines running, no meaningful thrust)
// gphMax:      fuel flow at typical cruise thrust (long-range cruise setting)
//              NOTE: for SimBrief parity, gphMax should reflect LRC/MRC cruise
//              burn, NOT max continuous climb thrust.
// isJet:       true = jet/turbofan burn model; false = piston/turboprop
// isTurboprop: true = turboprop (uses Jet-A density), false = piston (AvGas)
// hasAB:       has afterburner
// capacity:    usable fuel in US gallons
//
// Sources: aircraft POH, airline ops specs, manufacturer data, SimBrief OFP,
// Wikipedia, Airbus/Boeing airport planning documents.
//
// ─── A350-900 fuel model notes ──────────────────────────────────────────────
// SimBrief uses EZFW/OFP data based on real airline fuel burn reports.
// Rolls-Royce Trent XWB-84 cruise fuel flow (per engine, LRC, FL390):
//   ~6,500–7,000 kg/hr per engine → ~13,000–14,000 kg/hr total
//   = ~4,275–4,600 gph total at cruise
// Max continuous (climb/TO thrust): ~8,500 kg/hr per engine = ~17,000 total
//   = ~5,590 gph — this was the wrong value used before.
// Idle descent/taxi: ~350 gph total (unchanged).
// Capacity: 158,000 L usable = 41,737 US gal (unchanged).
//
// The old gphMax of 2400 was for max continuous power; for SimBrief to match,
// the cruise value (~4,450 gph at full throttle proxy) is more appropriate
// because GeoFS runs cruise throttle well below "max continuous" physically.
// Tuned so that at typical cruise throttle (~0.7–0.75 in GeoFS), burn ≈
// 13,500 kg/hr, matching SimBrief LRC fuel planning for the A350-900.
// ────────────────────────────────────────────────────────────────────────────
window.fuel.getStats = function (id) {
    const stats = {
        // id: { gphIdle, gphMax, capacity, isJet, isTurboprop, hasAB }

        // 1 — Cessna 172 Skyhawk
        // Lycoming IO-360, ~8.5 gph cruise, ~6 idle
        1: { gphIdle: 3.0,  gphMax: 8.5,   capacity: 53,     isJet: false, isTurboprop: false, hasAB: false },

        // 2 — Piper PA-28 Cherokee
        // Lycoming O-360, ~7-9 gph
        2: { gphIdle: 2.5,  gphMax: 9.0,   capacity: 50,     isJet: false, isTurboprop: false, hasAB: false },

        // 3 — Beechcraft King Air C90 (turboprop)
        // PT6A-21, ~65-80 gph total both engines at cruise
        3: { gphIdle: 30.0, gphMax: 80.0,  capacity: 384,    isJet: false, isTurboprop: true,  hasAB: false },

        // 4 — Boeing 737-800
        // CFM56-7B, ~900 gph total cruise, idle ~200 gph total
        4: { gphIdle: 200,  gphMax: 900,   capacity: 6875,   isJet: true,  isTurboprop: false, hasAB: false },

        // 5 — Diamond DA42 Twin Star
        // Austro AE300 diesels, ~7 gph each at cruise = 14 total
        5: { gphIdle: 4.0,  gphMax: 14.0,  capacity: 50,     isJet: false, isTurboprop: false, hasAB: false },

        // 6 — Cirrus SR22
        // Continental IO-550, ~14-16 gph cruise
        6: { gphIdle: 4.0,  gphMax: 16.0,  capacity: 92,     isJet: false, isTurboprop: false, hasAB: false },

        // 7 — F/A-18 Hornet
        // Two F404-GE-400, ~3900 lb/hr each military power ≈ ~1160 gph total
        // Afterburner approx 2× that
        7: { gphIdle: 200,  gphMax: 1160,  capacity: 1583,   isJet: true,  isTurboprop: false, hasAB: true  },

        // 8 — Robinson R22 helicopter
        // Lycoming O-320, ~8 gph
        8: { gphIdle: 3.0,  gphMax: 8.0,   capacity: 19,     isJet: false, isTurboprop: false, hasAB: false },

        // 9 — Cessna Citation CJ1 (light jet)
        // Williams FJ44-1A, ~100 gph total cruise
        9: { gphIdle: 25.0, gphMax: 120.0, capacity: 557,    isJet: true,  isTurboprop: false, hasAB: false },

        // 10 — Airbus A380
        // Four GP7270 engines, cruise ~3200 gph total, idle ~800 gph
        10: { gphIdle: 800, gphMax: 3200,  capacity: 84535,  isJet: true,  isTurboprop: false, hasAB: false },

        // 11 — Electric aircraft (DG Flugzeugbau e-Star)
        // Not fuel — electric kWh. We store kWh as "gallons" and kW as "gph" (1:1 proxy)
        11: { gphIdle: 0.5, gphMax: 4.3,   capacity: 22,     isJet: false, isTurboprop: false, hasAB: false },

        // 12 — Piper J-3 Cub
        // Continental A-65, ~4.5 gph
        12: { gphIdle: 1.5, gphMax: 4.5,   capacity: 12,     isJet: false, isTurboprop: false, hasAB: false },

        // 13 — Cessna 208 Caravan (turboprop)
        // PT6A-114A, ~35-45 gph cruise
        13: { gphIdle: 15.0, gphMax: 46.0, capacity: 335,    isJet: false, isTurboprop: true,  hasAB: false },

        // 14 — Ultralight / weight-shift
        // Small 2-stroke, ~3-5 gph
        14: { gphIdle: 1.0, gphMax: 4.0,   capacity: 8,      isJet: false, isTurboprop: false, hasAB: false },

        // 15 — Beechcraft Baron 58
        // Two Continental IO-550, ~20 gph each = 40 total
        15: { gphIdle: 10.0, gphMax: 40.0, capacity: 166,    isJet: false, isTurboprop: false, hasAB: false },

        // 16 — Bombardier Dash 8 Q400 (turboprop)
        // Two PW150A, ~220 gph total cruise
        16: { gphIdle: 60.0, gphMax: 220.0, capacity: 1589,  isJet: false, isTurboprop: true,  hasAB: false },

        // 18 — Boeing 767-300
        // Two CF6-80C2, ~1200 gph total cruise, idle ~280 gph
        18: { gphIdle: 280, gphMax: 1200,  capacity: 23980,  isJet: true,  isTurboprop: false, hasAB: false },

        // 20 — Boeing 747-400
        // Four CF6-80C2, total cruise ~3600 gph, idle ~900 gph
        20: { gphIdle: 900, gphMax: 3600,  capacity: 57285,  isJet: true,  isTurboprop: false, hasAB: false },

        // 21 — Schleicher ASK 21 glider (no engine — near zero)
        21: { gphIdle: 0.0, gphMax: 0.1,   capacity: 0,      isJet: false, isTurboprop: false, hasAB: false },

        // 22 — Tecnam P2002 Sierra
        // Rotax 912ULS, ~5 gph cruise
        22: { gphIdle: 1.5, gphMax: 5.0,   capacity: 26,     isJet: false, isTurboprop: false, hasAB: false },

        // 23 — Aquila A210
        // Lycoming O-320-D1A, ~6.5 gph
        23: { gphIdle: 2.0, gphMax: 6.5,   capacity: 30,     isJet: false, isTurboprop: false, hasAB: false },

        // 24 — Airbus A350-900  ★ SimBrief-aligned fix ★
        // Two Rolls-Royce Trent XWB-84
        //
        // Real-world cruise burn (LRC, FL390, ISA):
        //   ~6,500–7,000 kg/hr per engine = ~13,500 kg/hr total
        //   = ~4,435 gph total
        //
        // SimBrief OFP fuel = block fuel for planned trip; this gphMax is
        // calibrated so that at typical GeoFS cruise throttle (≈0.72–0.75),
        // the sqrt-curve yields ~4,300–4,600 gph → ~13,000–14,000 kg/hr,
        // matching SimBrief LRC burn rates.
        //
        // gphMax set to the value that, when fed through sqrt(0.75) ≈ 0.866,
        // produces ~4,435 gph:  4435 / 0.866 ≈ 5,120 gph (full throttle max)
        //
        // Idle (taxi/descent): ~350 gph total (unchanged, matches ACARS data)
        // Capacity: 158,000 L usable = 41,737 US gal
        24: { gphIdle: 350, gphMax: 5120,  capacity: 41737,  isJet: true,  isTurboprop: false, hasAB: false },

        // 25 — Airbus A340-600
        // Four CFM56-5C4, total cruise ~2800 gph, idle ~700 gph
        25: { gphIdle: 700, gphMax: 2800,  capacity: 51750,  isJet: true,  isTurboprop: false, hasAB: false },

        // 26 — ATR 72-600 (turboprop)
        // Two PW127M, ~130 gph total cruise
        26: { gphIdle: 35.0, gphMax: 130.0, capacity: 1543,  isJet: false, isTurboprop: true,  hasAB: false },

        // 27 — Cessna Citation X
        // Two Rolls-Royce AE 3007C, ~290 gph total cruise
        27: { gphIdle: 70.0, gphMax: 290.0, capacity: 1327,  isJet: true,  isTurboprop: false, hasAB: false },

        // 28 — Piper PA-46 Malibu Meridian (turboprop)
        // PT6A-42A, ~38 gph cruise
        28: { gphIdle: 10.0, gphMax: 38.0, capacity: 120,    isJet: false, isTurboprop: true,  hasAB: false },

        // 31 — Extra 330 (aerobatic piston)
        // Lycoming AEIO-580, ~17 gph full power
        31: { gphIdle: 4.0, gphMax: 17.0,  capacity: 48,     isJet: false, isTurboprop: false, hasAB: false },

        // 40 — Paramotor / powered parachute
        // Small 2-stroke, ~1.5-2.5 gph
        40: { gphIdle: 0.5, gphMax: 2.5,   capacity: 4,      isJet: false, isTurboprop: false, hasAB: false },
    };

    const s = stats[id] || { gphIdle: -1, gphMax: -1, capacity: -1, isJet: false, isTurboprop: false, hasAB: false };
    s.capacity = s.capacity > 0 ? s.capacity : -1;
    return s;
};
